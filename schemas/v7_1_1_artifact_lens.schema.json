{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "odin.v7_1_1.artifact_lens.schema",
  "title": "Odin v7.1.1 Artifact Lens",
  "description": "Defines a transformation lens applicable to artifact families",
  "type": "object",
  "required": ["lens_id", "lens_name", "applicable_families", "input_kind", "output_kind", "claim_boundary", "candidate_only"],
  "properties": {
    "lens_id": {"type": "string"},
    "lens_name": {"type": "string"},
    "applicable_families": {"type": "array", "items": {"type": "string"}},
    "input_kind": {"type": "string"},
    "output_kind": {"type": "string"},
    "description": {"type": "string"},
    "claim_boundary": {"type": "string"},
    "candidate_only": {"type": "boolean", "const": true},
    "non_claims": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
