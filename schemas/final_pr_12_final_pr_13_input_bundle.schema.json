{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FINAL-PR-13 Input Bundle",
  "type": "object",
  "required": [
    "artifact_kind",
    "candidate_only",
    "claim_boundary",
    "final_pr_13_remains_deferred",
    "forbidden_claims"
  ],
  "properties": {
    "artifact_kind": {
      "type": "string"
    },
    "candidate_only": {
      "type": "boolean",
      "const": true
    },
    "claim_boundary": {
      "type": "string"
    },
    "final_pr_13_remains_deferred": {
      "type": "boolean",
      "const": true
    },
    "forbidden_claims": {
      "type": "array"
    },
    "not_proven": {
      "type": "array"
    }
  }
}