{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FINAL-PR-12 Packaging Boundary",
  "type": "object",
  "required": [
    "artifact_kind",
    "candidate_only",
    "claim_boundary",
    "items"
  ],
  "properties": {
    "artifact_kind": {
      "type": "string"
    },
    "candidate_only": {
      "type": "boolean",
      "const": true
    },
    "claim_boundary": {
      "type": "string"
    },
    "items": {
      "type": "array"
    },
    "not_proven": {
      "type": "array"
    }
  }
}