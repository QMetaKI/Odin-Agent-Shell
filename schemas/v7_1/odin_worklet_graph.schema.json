{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://odin-agent-shell.local/schemas/v7_1/odin_worklet_graph.schema.json",
  "title": "odin_worklet_graph",
  "type": "object",
  "required": ["artifact_kind", "protocol_version", "graph_id", "work_id", "worklets", "candidate_only", "claim_boundary"],
  "properties": {
    "artifact_kind": {"const": "odin_worklet_graph"},
    "protocol_version": {"const": "7.1"},
    "graph_id": {"type": "string"},
    "work_id": {"type": "string"},
    "worklets": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "object",
        "required": ["worklet_id", "depends_on", "atoms"],
        "properties": {
          "worklet_id": {"type": "string"},
          "depends_on": {"type": "array", "items": {"type": "string"}},
          "atoms": {"type": "array", "maxItems": 12, "items": {"type": "string"}}
        },
        "additionalProperties": false
      }
    },
    "candidate_only": {"const": true},
    "claim_boundary": {"type": "string"}
  },
  "additionalProperties": false
}
