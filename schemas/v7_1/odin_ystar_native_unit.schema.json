{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "title": "Odin YStar Native Unit",
  "properties": {
    "artifact_kind": {
      "const": "odin_ystar_native_unit"
    },
    "protocol_version": {
      "const": "7.1"
    },
    "unit_id": {
      "type": "string"
    },
    "story_ref": {
      "type": "string"
    },
    "center": {
      "type": "object",
      "additionalProperties": true
    },
    "rings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "flow": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forbidden": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "emits": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "holes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "confidence": {
      "type": "object",
      "additionalProperties": true
    },
    "claim_boundary": {
      "type": "string"
    }
  },
  "required": [
    "artifact_kind",
    "protocol_version",
    "unit_id",
    "story_ref",
    "center",
    "rings",
    "flow",
    "forbidden",
    "emits",
    "holes",
    "confidence",
    "claim_boundary"
