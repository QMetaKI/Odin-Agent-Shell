{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_kind",
    "function_id",
    "function_kind",
    "input_refs",
    "output_hint",
    "forbidden_actions",
    "claim_boundary"
  ],
  "properties": {
    "artifact_kind": {
      "type": "string"
    },
    "function_id": {
      "type": "string"
    },
    "function_kind": {
      "type": "string"
    },
    "input_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "output_hint": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forbidden_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "claim_boundary": {
      "type": "string"
    }
  }
}
