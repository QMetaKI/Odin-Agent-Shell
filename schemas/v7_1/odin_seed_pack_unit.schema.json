{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_kind",
    "seed_id",
    "seed_family",
    "activation_tags",
    "scope",
    "constraints",
    "claim_boundary"
  ],
  "properties": {
    "artifact_kind": {
      "type": "string"
    },
    "seed_id": {
      "type": "string"
    },
    "seed_family": {
      "type": "string"
    },
    "activation_tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scope": {
      "type": "string"
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "claim_boundary": {
      "type": "string"
    }
  }
}
